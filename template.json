                "denyEncryptionScopeOverride": false,
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2026-04-01",
            "name": "[concat(parameters('storageAccounts_stcdltd2026_name'), '/default/hr-records')]",
